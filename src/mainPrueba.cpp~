#include <iostream>

int main() {

    GrafoAdList<std::string, int> g(false); // grafo no dirigido

    // Agregar vértices
    g.addVertice("A");
    g.addVertice("B");
    g.addVertice("C");

    std::cout << "Vertices: "
              << g.getNumVertices() << std::endl;

    // Agregar aristas
    g.addArista("A", "B", 10);
    g.addArista("A", "C", 20);

    std::cout << "Aristas: "
              << g.getNumAristas() << std::endl;

    // Adyacencia
    std::cout << "A y B son adyacentes? "
              << g.sonAdyacentes("A", "B")
              << std::endl;

    // Vecinos
    std::cout << "\nVecinos de A:\n";

    for(const auto& v : g.getVecinos("A")) {
        std::cout << v << std::endl;
    }

    // Grado
    std::cout << "\nGrado de A: "
              << g.getGrado("A")
              << std::endl;

    // Mostrar vértices
    std::cout << "\nVertices del grafo:\n";

    for(const auto& v : g.getVertices()) {
        std::cout << v << std::endl;
    }

    // Mostrar aristas
    std::cout << "\nAristas del grafo:\n";

    for(const auto& a : g.getAristas()) {
        std::cout << a.origen
                  << " -> "
                  << a.destino
                  << " peso="
                  << a.peso
                  << std::endl;
    }

    // Reemplazar peso
    g.replaceArista({"A","B",10},50);

    std::cout << "\nDespues de replaceArista:\n";

    for(const auto& a : g.getAristas()) {
        std::cout << a.origen
                  << " -> "
                  << a.destino
                  << " peso="
                  << a.peso
                  << std::endl;
    }

    // Reemplazar vértice
    g.replaceVertice("C","D");

    std::cout << "\nDespues de replaceVertice(C,D):\n";

    for(const auto& v : g.getVertices()) {
        std::cout << v << std::endl;
    }

    // Eliminar arista
    g.removeAristaWV("A","B");

    std::cout << "\nAristas despues de eliminar A-B:\n";

    for(const auto& a : g.getAristas()) {
        std::cout << a.origen
                  << " -> "
                  << a.destino
                  << " peso="
                  << a.peso
                  << std::endl;
    }

    // Eliminar vértice
    g.removeVertice("D");

    std::cout << "\nVertices despues de eliminar D:\n";

    for(const auto& v : g.getVertices()) {
        std::cout << v << std::endl;
    }

    std::cout << "\nNumero de aristas: "
              << g.getNumAristas()
              << std::endl;

    return 0;
}
